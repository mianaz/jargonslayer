{
  "compilerOptions": {
    "target": "ES2017",
    // No "dom"/"dom.iterable" on purpose — this package must stay
    // React/DOM-free (#53 core extraction, PLAN-v0.4 §1D). Any
    // accidental `document`/`window`/browser-global reference fails
    // typecheck here as an undefined name, on top of the grep check
    // and the DOM-freeness unit test (see src/__tests__/).
    "lib": ["ES2022"],
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
