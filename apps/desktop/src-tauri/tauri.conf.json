{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JargonSlayer",
  "identifier": "com.bioinfospace.jargonslayer",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev -w apps/web --prefix ../..",
    "beforeBuildCommand": "npm run build:desktop --prefix ../.."
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JargonSlayer",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:* https:; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/uv"],
    "resources": {
      "../../../sidecar/whisper_server.py": "sidecar/whisper_server.py",
      "../../../sidecar/requirements-sidecar.txt": "sidecar/requirements-sidecar.txt"
    },
    "macOS": {
      "entitlements": "./entitlements.plist"
    }
  }
}
