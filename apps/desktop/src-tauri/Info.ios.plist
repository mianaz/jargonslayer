<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- S13 (docs/design-explorations/s13-ios-blueprint.md, §D5) — Tauri
	     auto-searches Info.plist and Info.ios.plist in the config dir and
	     merges them for the iOS build; this file supplies the two usage
	     strings the mic-only 系统识别 native plugin (Lane B) needs.
	     No NSAudioCaptureUsageDescription here — v1 iOS has no app-audio-tap
	     (D6: mic-only, foreground-only). -->
	<key>NSMicrophoneUsageDescription</key>
	<string>JargonSlayer 需要麦克风来实时识别会议语音</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>JargonSlayer 使用设备端语音识别把会议内容转写为文字</string>
</dict>
</plist>
