{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window — core defaults, the uv sidecar spawn permission, and BYOK-provider HTTP access.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/uv",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://**" },
        { "url": "http://localhost:*" },
        { "url": "http://127.0.0.1:*" }
      ]
    }
  ]
}
