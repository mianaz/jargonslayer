node_modules/
.next/
out/
build/
*.log
.DS_Store
.env
.env.local
.env*.local
*.tsbuildinfo
next-env.d.ts.bak

# python sidecar
sidecar/__pycache__/
sidecar/.venv/
sidecar/*.wav

# local agent harness config
.claude/

# ffmpeg.wasm runtime copied from node_modules on postinstall
/apps/web/public/ffmpeg/

# internal working docs (strategy/research/spec drafts) — private nested repo, never public
/docs/

# CRXJS/Vite build output (S6) — the loadable unpacked extension,
# rebuilt on demand via `npm run build:extension`; not source.
/apps/extension/dist/

# Tauri desktop shell (S3) — the uv sidecar binary, downloaded per-
# machine by `node scripts/fetch-uv.mjs` against sha256 digests pinned
# in that script (not fetched from the release at install time — see
# UV_SHA256 there), plus that script's own machine-local record of the
# verified install (binaries/.uv-<triple>.sha256). Pinned uv version is
# tracked in the script, not git.
/apps/desktop/src-tauri/binaries/

# v0.4 S9.1 (docs/design-explorations/s9-app-audio-tap-blueprint.md) —
# the jargonslayer-audiocap sidecar binary, built per-machine by
# `node scripts/build-audiocap.mjs` from apps/desktop/src-tauri/
# audiocap-helper/ (a Swift package, no download/checksum to pin — the
# source it's built from IS the checksum). Already covered by the
# broader /apps/desktop/src-tauri/binaries/ ignore above; called out
# explicitly here too, next to the uv pattern, for anyone scanning this
# file for "what's a staged sidecar binary."
binaries/jargonslayer-audiocap-*
